export PATH="$HOME/bin:/usr/local/bin:/Applications/love.app/Contents/MacOS:/opt/homebrew/opt/openjdk@17/bin:$HOME/.deno/env:$HOME/.deno/bin:$PATH"
export ZSH="$HOME/.oh-my-zsh"
export ANDROID_HOME="$HOME/Library/Android/sdk"
export EDITOR=nvim

CASE_SENSITIVE="true"

zstyle ':omz:update' mode auto      # update automatically without asking

plugins=(
    git
    zsh-syntax-highlighting
    zsh-autosuggestions
)

source $ZSH/oh-my-zsh.sh

# vi bidings
set -o vi

# Extract
# usage: ex <file>
ex()
{
    if [ -f $1 ] ; then
        case $1 in
            *.tar.bz2)  tar xjf $1  ;;
            *.tar.gx)   tar xzf $1  ;;
            *.bz2)      bunzip2 $1  ;;
            *.rar)      unrar x $1  ;;
            *.gz)       gunzip $1   ;;
            *.tar)      tar xf $1   ;;
            *.tbz2)     tar xjf $1  ;;
            *.tgz)      tar xzf $1  ;;
            *.zip)      unzip $1    ;;
            *.Z)        uncompress $1;;
            *.7z)       7z x $1     ;;
            *.deb)      ar x $1     ;;
            *.tar.xz)   tar xf $1   ;;
            *.tar.zst)  unzstd $1   ;;
            *)          echo "'$1' cannot be extracted via ex()" ;;
        esac
    else
        echo "'$1' is not a valid file"
    fi
}

# Programs
alias ls="eza -al --color=always --group-directories-first" # best listing
alias la="eza -a --color=always --group-directories-first"  # all files and dirs
alias ll="eza -l --color=always --group-directories-first"  # long format
alias lt="eza -aT --color=always --group-directories-first" # tree listing
alias l.="eza -a | egrep '^\.'"                             # just list dot files
alias explores="yazi"
alias nchat="TERM=xterm-256color nchat"

alias cp="cp -i"    # confirm before overwriting something
alias df="df -h"    # human-readable sizes
alias vim="nvim"
alias cat="bat"

# Tmux
alias t-sessions="tmux ls"
alias t-new="tmux new -s"
alias t-kill="tmux kill-session -t"
alias t-session="tmux attach -t"
alias t-quit="tmux kill-server"

# Flutter
alias flutter-generate="dart run build_runner build --delete-conflicting-outputs"

eval "$(zoxide init --cmd cd zsh)"
eval "$(starship init zsh)"

export NVM_DIR="$([ -z "${XDG_CONFIG_HOME-}" ] && printf %s "${HOME}/.nvm" || printf %s "${XDG_CONFIG_HOME}/nvm")"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh" # This loads nvm



# Load Angular CLI autocompletion.
source <(ng completion script)

fpath=(~/.zsh/completion $fpath)
autoload -U compinit
compinit


# The next line updates PATH for the Google Cloud SDK.
if [ -f '/Users/feels/Libraries/google-cloud-sdk/path.zsh.inc' ]; then . '/Users/feels/Libraries/google-cloud-sdk/path.zsh.inc'; fi

# The next line enables shell command completion for gcloud.
if [ -f '/Users/feels/Libraries/google-cloud-sdk/completion.zsh.inc' ]; then . '/Users/feels/Libraries/google-cloud-sdk/completion.zsh.inc'; fi

# opencode
export PATH=/Users/feels/.opencode/bin:$PATH
